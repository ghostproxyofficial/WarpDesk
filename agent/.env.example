# CREATE A FILE NAMED .env.local IN THIS DIRECTORY WITH THE CONTENTS OF THIS FILE, AND REPLACE THE PLACEHOLDER VALUES WITH YOUR REAL CONFIGURATION.
# Copy this file to agent/.env.local and replace placeholder values.
# Do NOT commit your real tokens.

# Basic host settings
WARPDESK_PORT=8443
WARPDESK_USER=admin
WARPDESK_PASSWORD=warpdesk

# Cloudflare TURN short-lived credential settings
# Set to true to fetch short-lived TURN credentials from Cloudflare.
# Set to false to disable Cloudflare TURN and use static/fallback ICE config only.
CLOUDFLARE_TURN=true
WARPDESK_CF_TURN_TOKEN_ID=replace_with_cloudflare_turn_token_id
WARPDESK_CF_TURN_API_TOKEN=replace_with_cloudflare_api_token
WARPDESK_CF_TURN_TTL_SECONDS=3600
WARPDESK_CF_TURN_API_BASE=https://rtc.live.cloudflare.com/v1
WARPDESK_CF_TURN_TIMEOUT_SECONDS=8

# Optional fallback static TURN (used if Cloudflare vars above are not set)
# WARPDESK_TURN_URLS=turn:turn.example.com:3478?transport=udp,turns:turn.example.com:5349?transport=tcp
# WARPDESK_TURN_USERNAME=replace_me
# WARPDESK_TURN_CREDENTIAL=replace_me

# Optional host-side GStreamer ICE hints
# WARPDESK_GST_STUN_SERVER=stun://stun.l.google.com:19302
# WARPDESK_GST_TURN_SERVER=turn://user:pass@turn.example.com:3478
